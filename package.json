{
  "name": "road-clash",
  "private": true,
  "version": "2.2.0",
  "type": "module",
  "description": "Road Clash — a pseudo-3D Road Rash-style combat racer with solo + P2P multiplayer",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview --port 4173",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "deploy": "npm run build && wrangler pages deploy dist --project-name road-clash"
  },
  "devDependencies": {
    "typescript": "^5.6.3",
    "vite": "^5.4.11",
    "vitest": "^2.1.8",
    "wrangler": "^3.95.0"
  },
  "dependencies": {
    "@vercel/analytics": "^2.0.1",
    "@vercel/speed-insights": "^2.0.0",
    "trystero": "^0.21.5"
  }
}
